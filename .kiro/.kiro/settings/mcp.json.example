{
  "mcpServers": {
    "_comment": "ワークスペース共有のMCPサーバー設定テンプレート。このファイルをコピーして mcp.json を作成してください。",
    "aws-docs": {
      "command": "uvx",
      "args": ["awslabs.aws-documentation-mcp-server@latest"],
      "env": {
        "FASTMCP_LOG_LEVEL": "ERROR"
      },
      "disabled": true,
      "autoApprove": []
    }
  },
  "powers": {
    "mcpServers": {
      "power-postman-postman": {
        "url": "https://mcp.postman.com/minimal",
        "headers": {
          "Authorization": "Bearer ${POSTMAN_API_KEY}"
        },
        "disabled": true,
        "_setup": "Postman API Key を https://postman.com/settings/me/api-keys で取得し、環境変数 POSTMAN_API_KEY に設定"
      },
      "power-figma-figma": {
        "type": "http",
        "url": "https://mcp.figma.com/mcp",
        "disabledTools": [],
        "_setup": "Figma Power をインストール後、Kiro が自動設定します"
      }
    }
  }
}
