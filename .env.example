# ============================================================================
# Payment Compliance Monitor - Environment Variables Configuration
# ============================================================================
# 
# This file contains all environment variables required for the application.
# Copy this file to .env and update the values for your environment.
#
# IMPORTANT: Never commit .env file to version control!
# ============================================================================

# ============================================================================
# Database Configuration
# ============================================================================
# PostgreSQL database settings for storing monitoring data

# Database user (default: payment_monitor)
POSTGRES_USER=payment_monitor

# Database password (CHANGE IN PRODUCTION!)
POSTGRES_PASSWORD=payment_monitor_pass

# Database name (default: payment_monitor)
POSTGRES_DB=payment_monitor

# Database host (use 'postgres' for Docker, 'localhost' for local dev)
POSTGRES_HOST=postgres

# Database port (default: 5432)
POSTGRES_PORT=5432

# Full database connection URL
# Format: postgresql+asyncpg://user:password@host:port/database
DATABASE_URL=postgresql+asyncpg://payment_monitor:payment_monitor_pass@postgres:5432/payment_monitor

# ============================================================================
# Redis Configuration
# ============================================================================
# Redis is used for caching, rate limiting, and Celery message broker

# Redis host (use 'redis' for Docker, 'localhost' for local dev)
REDIS_HOST=redis

# Redis port (default: 6379)
REDIS_PORT=6379

# Full Redis connection URL
REDIS_URL=redis://redis:6379/0

# ============================================================================
# Celery Configuration
# ============================================================================
# Celery task queue settings for background jobs

# Celery broker URL (uses Redis)
CELERY_BROKER_URL=redis://redis:6379/0

# Celery result backend (uses Redis)
CELERY_RESULT_BACKEND=redis://redis:6379/0

# ============================================================================
# API Configuration
# ============================================================================
# FastAPI application settings

# API server port (default: 8000)
API_PORT=8000

# API server host (0.0.0.0 for all interfaces)
API_HOST=0.0.0.0

# CORS allowed origins (comma-separated)
# Example: http://localhost:3000,https://yourdomain.com
CORS_ORIGINS=http://localhost:3000

# ============================================================================
# Security Configuration
# ============================================================================
# CRITICAL: Change all keys in production!

# General secret key for application (min 32 characters)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-secret-key-here-change-in-production

# Encryption key for sensitive data (must be 32 bytes base64 encoded)
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your-encryption-key-here-change-in-production

# JWT secret key for authentication (min 32 characters)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=your-jwt-secret-key-here-change-in-production

# JWT algorithm (default: HS256)
JWT_ALGORITHM=HS256

# Access token expiration time in minutes (default: 30)
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Initial admin username (default: hjkim93)
ADMIN_USERNAME=hjkim93

# Initial admin password (leave empty to auto-generate on first startup)
ADMIN_PASSWORD=

# ============================================================================
# Email Notification Configuration (SendGrid)
# ============================================================================
# SendGrid API for sending email alerts

# SendGrid API key (get from https://sendgrid.com)
SENDGRID_API_KEY=your-sendgrid-api-key-here

# From email address for alerts
SENDGRID_FROM_EMAIL=alerts@example.com

# Default recipient email addresses (comma-separated)
ALERT_EMAIL_RECIPIENTS=admin@example.com,security@example.com

# ============================================================================
# Slack Notification Configuration
# ============================================================================
# Slack integration for real-time alerts

# Slack bot token (starts with xoxb-)
# Get from: https://api.slack.com/apps
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token-here

# Slack channel ID for alerts
SLACK_CHANNEL_ID=your-slack-channel-id-here

# Slack webhook URL (alternative to bot token)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# ============================================================================
# Web Crawler Configuration
# ============================================================================
# Settings for the Playwright-based web crawler

# Rate limit between requests (seconds)
CRAWLER_RATE_LIMIT_SECONDS=10

# Maximum time for a single crawl operation (seconds)
CRAWLER_TIMEOUT_SECONDS=300

# Maximum number of retry attempts on failure
CRAWLER_MAX_RETRIES=3

# User agent string for crawler
CRAWLER_USER_AGENT=PaymentComplianceMonitor/1.0

# Respect robots.txt (true/false)
CRAWLER_RESPECT_ROBOTS_TXT=true

# ============================================================================
# Monitoring Configuration
# ============================================================================
# Settings for monitoring and data retention

# Number of days to retain monitoring history (default: 365)
MONITORING_HISTORY_RETENTION_DAYS=365

# Maximum number of retry attempts for alerts
ALERT_RETRY_MAX_ATTEMPTS=3

# Alert retry delay (seconds)
ALERT_RETRY_DELAY_SECONDS=60

# ============================================================================
# Fake Site Detection Configuration
# ============================================================================
# Thresholds for detecting fake/phishing sites

# Domain similarity threshold (0.0-1.0, higher = more similar)
# Domains above this threshold are flagged as suspicious
FAKE_SITE_DOMAIN_SIMILARITY_THRESHOLD=0.8

# Content similarity threshold (0.0-1.0, higher = more similar)
# Content above this threshold is flagged as suspicious
FAKE_SITE_CONTENT_SIMILARITY_THRESHOLD=0.7

# ============================================================================
# Scheduled Tasks Configuration
# ============================================================================
# Celery Beat schedule settings

# Daily crawling time (cron format: minute hour)
# Default: 2:00 AM
DAILY_CRAWL_HOUR=2
DAILY_CRAWL_MINUTE=0

# Weekly fake site scan day (0=Monday, 6=Sunday)
# Default: Monday at 3:00 AM
WEEKLY_SCAN_DAY=0
WEEKLY_SCAN_HOUR=3
WEEKLY_SCAN_MINUTE=0

# Monthly cleanup day (1-31)
# Default: 1st of month at 4:00 AM
MONTHLY_CLEANUP_DAY=1
MONTHLY_CLEANUP_HOUR=4
MONTHLY_CLEANUP_MINUTE=0

# ============================================================================
# Application Environment
# ============================================================================
# General application settings

# Environment (development, staging, production)
ENVIRONMENT=development

# Debug mode (true/false) - MUST be false in production!
DEBUG=true

# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# ============================================================================
# Optional: External Services
# ============================================================================

# Sentry DSN for error tracking (optional)
# SENTRY_DSN=https://your-sentry-dsn-here

# New Relic license key for APM (optional)
# NEW_RELIC_LICENSE_KEY=your-new-relic-key-here

# ============================================================================
# Data Extraction & Screenshot Configuration
# ============================================================================
# Settings for the crawl data extraction and screenshot features

# Enable/disable automatic screenshot capture (true/false)
# Requirement: 24.1
SCREENSHOT_ENABLED=true

# Enable/disable structured data extraction (true/false)
# Requirement: 24.2
EXTRACTION_ENABLED=true

# Screenshot quality level (low, medium, high)
# Requirement: 24.3
SCREENSHOT_QUALITY=medium

# Screenshot capture timeout in seconds
SCREENSHOT_TIMEOUT=10

# Directory for storing screenshots (relative to project root)
SCREENSHOT_DIR=screenshots

# Number of days to retain screenshots before automatic cleanup
SCREENSHOT_RETENTION_DAYS=90

# Minimum confidence score threshold for extracted data (0.0-1.0)
# Fields below this threshold are flagged for manual review
# Requirement: 24.4
CONFIDENCE_THRESHOLD=0.5

# Price change percentage threshold for generating alerts
# Requirement: 24.5
PRICE_CHANGE_ALERT_THRESHOLD=20.0

# API key for external service access (development only)
API_KEY=dev-api-key

# ============================================================================
# Development Only
# ============================================================================
# These settings should only be used in development

# Enable API documentation (true/false)
# Set to false in production for security
ENABLE_DOCS=true

# Enable CORS (true/false)
# Set to false in production or configure CORS_ORIGINS properly
ENABLE_CORS=true

# ============================================================================
# Notes
# ============================================================================
#
# 1. Security Keys:
#    - Generate strong random keys for production
#    - Never reuse keys across environments
#    - Rotate keys periodically
#
# 2. Database:
#    - Use strong passwords in production
#    - Enable SSL/TLS for database connections
#    - Regular backups are essential
#
# 3. Redis:
#    - Configure password authentication in production
#    - Use Redis Sentinel or Cluster for high availability
#
# 4. Email/Slack:
#    - Test notification settings before production
#    - Monitor API rate limits
#
# 5. Crawler:
#    - Respect robots.txt and rate limits
#    - Monitor for IP blocking
#
# 6. Monitoring:
#    - Adjust retention based on storage capacity
#    - Archive old data before deletion
#
# ============================================================================
